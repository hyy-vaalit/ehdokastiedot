<dl>
  <dt><%= t(".name") %></dt>
  <dd><%= alliance.name %></dd>

  <% if alliance.advocate_user %>
    <dt><%= t(".advocate") %></dt>
    <dd><%= alliance.advocate_user&.friendly_name %></dd>

    <dt><%= t(".email") %></dt>
    <dd><%= alliance.advocate_user&.email %></dd>

    <% if alliance.advocate_user&.phone_number&.present? %>
      <dt><%= t(".phone") %></dt>
      <dd><%= alliance.advocate_user.phone_number %></dd>
    <% end %>
  <% end %>
</dl>
