<h2><%= t(".heading") %></h2>

<% @alliances = ElectoralAlliance.by_coalition_id.by_numbering_order %>

<% if @alliances.present? %>
  <table class="registrations-alliance-listing">
    <thead>
      <th><%= t(".alliance") %></th>
      <th><%= t(".coalition") %></th>
      <th><%= t(".advocate") %></th>
      <th></th>
    </thead>

    <tbody>
      <% ElectoralAlliance.by_coalition_id.by_numbering_order.each do |a| %>
        <tr>
          <td><%= a.name %></td>
          <td><%= a&.electoral_coalition&.name %></td>
          <td><%= a&.advocate_user&.friendly_name %></td>
          <td><%= a&.advocate_user&.email %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>
    <%= t(".none_yet") %>
  </p>
<% end %>
