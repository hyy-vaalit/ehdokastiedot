# Test environment configuration.
#
# Loaded automatically by dotenv-rails when RAILS_ENV=test.
# All values are dummies — nothing here is a secret.
#
# Request specs authenticate via the fake Haka authentication endpoint,
# which requires STAGE=development and FAKE_AUTH_ENABLED=yes.

STAGE="development"
FAKE_AUTH_ENABLED="yes"

TZ="Europe/Helsinki"

SITE_ADDRESS="http://www.example.com"
EMAIL_FROM_ADDRESS="HYYn vaalit <vaalit@example.com>"
EMAIL_FROM_NAME="Vaali Testaaja"

# Default test window: candidate nomination period is open.
# Specs that need another period stub GlobalConfiguration methods.
CANDIDATE_NOMINATION_STARTS_AT="2020-01-01 12:00:00 +0300"
CANDIDATE_NOMINATION_ENDS_AT="2099-01-01 12:00:00 +0300"
CANDIDATES_FROZEN_AT="2099-06-01 12:00:00 +0300"

ROLLBAR_ACCESS_TOKEN=""
ROLLBAR_ENV="test"

AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"

# Dummy SAML configuration — specs never perform a real SAML handshake.
SAML_IDP_SSO_TARGET_URL="https://idp.example.com/sso"
SAML_IDP_ENTITY_ID="https://idp.example.com/shibboleth"
SAML_ASSERTION_CONSUMER_SERVICE_URL="http://www.example.com/haka/auth/consume"
SAML_MY_ENTITY_ID="hyy.voting.test"
SAML_IDP_CERT_FINGERPRINT=""
SAML_NAME_IDENTIFIER_FORMAT="urn:oasis:names:tc:SAML:2.0:nameid-format:persistent"
SAML_IDP_CERT="dummy"
SAML_MY_PRIVATE_KEY="dummy"
SAML_MY_CERT="dummy"

HAKA_STUDENT_NUMBER_FIELD="urn:oid:1.3.6.1.4.1.25178.1.2.14"
HAKA_STUDENT_NUMBER_KEY="urn:schac:personalUniqueCode:fi:yliopisto.fi"
HAKA_EMAIL_FIELD="urn:oid:0.9.2342.19200300.100.1.3"
HAKA_CN_FIELD="urn:oid:2.5.4.3"
HAKA_SN_FIELD="urn:oid:2.5.4.4"
HAKA_GIVENNAME_FIELD="urn:oid:2.5.4.42"
HAKA_HOMEORG_FIELD="urn:oid:1.3.6.1.4.1.25178.1.2.9"
